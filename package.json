{
  "engines": {
    "node": "24.x"
  },
  "name": "freelanceflow-dach",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm:dev:web\" \"npm:dev:server\"",
    "dev:web": "vite",
    "dev:server": "node server/index.js",
    "build": "vite build",
    "typecheck": "tsc --noEmit",
    "preview": "vite preview",
    "test": "playwright test",
    "test:e2e": "playwright test",
    "test:server": "node --test server/tests/*.test.js",
    "test:ui": "vitest run",
    "test:all": "npm run typecheck && npm run test:ui && npm run test:server && npm run build",
    "audit": "npm audit --audit-level=high"
  },
  "dependencies": {
    "@sparticuz/chromium": "149.0.0",
    "@supabase/supabase-js": "2.110.2",
    "dotenv": "^16.5.0",
    "express": "^5.1.0",
    "lucide-react": "^0.556.0",
    "nodemailer": "9.0.3",
    "openai": "6.46.0",
    "playwright-core": "1.61.1",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "react-router-dom": "7.18.1",
    "redis": "^4.7.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "^14.5.2",
    "@types/node": "22.20.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "^5.0.0",
    "autoprefixer": "^10.4.19",
    "concurrently": "9.2.3",
    "jsdom": "^25.0.1",
    "playwright": "1.61.1",
    "postcss": "8.5.16",
    "tailwindcss": "^3.4.17",
    "typescript": "~5.8.2",
    "vite": "6.4.3",
    "vitest": "4.1.10"
  }
}
