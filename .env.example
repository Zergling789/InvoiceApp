# Account deletion worker. Enable only after the documented retention policy is approved.
CRON_SECRET=
ACCOUNT_DELETION_RETENTION_POLICY=

# Optional salt for irreversible user identifiers in structured server logs.
# Use a long random server-only value and keep it stable across deployments.
LOG_HASH_SALT=

# Stripe Billing (server-only). Price IDs are configured in Stripe Dashboard.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_SOLO_MONTHLY=
STRIPE_PRICE_SOLO_YEARLY=
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_PRO_YEARLY=

# Authenticated PDF/A-3 + EN16931 validation service. The token is server-only.
EINVOICE_GENERATOR_URL=
EINVOICE_GENERATOR_TOKEN=
# Generator container only; comma-separated current and previous token during rotation.
EINVOICE_GENERATOR_TOKENS=
GENERATOR_MAX_BODY_BYTES=22000000
GENERATOR_MAX_PDF_BYTES=10000000
GENERATOR_MAX_XML_BYTES=5000000
GENERATOR_TIMEOUT_MS=40000
GENERATOR_MAX_CONCURRENCY=2


